<%= f.input :name,
            input_html: {
              autocomplete: "off",
              autocorrect: "off",
              autocapitalize: "off",
              spellcheck: "false",
              autofocus: !turbo_native_app?,
              required: true
            } %>

<%= f.input :logo,
            as: :dropzone,
            input_html: { accept: "image/png, image/jpeg, image/gif" } %>

<%= f.hidden_field :website if f.object.new_record? %>
