<%= simple_form_for organization, html: { class: "contents space-y-4", data: { controller: "auto-submit", action: "keydown.ctrl+enter->auto-submit#submit keydown.meta+enter->auto-submit#submit" } } do |f| %>
  <%= render "shared/errors", object: f.object %>

  <%= render "organizations/organization_fields", f: f %>

  <div class="form-control">
    <%= f.label :privacy_setting, class: "label-text sr-only" %>

    <div class="space-y-3">
      <% Organization.privacy_settings.each do |key, value| %>
        <div class="flex items-center gap-3">
          <%= f.radio_button :privacy_setting, value, class: "radio mt-1" %>

          <%= f.label :"privacy_setting_#{value}", class: "flex flex-col cursor-pointer" do %>
            <span class="font-medium"><%= privacy_setting_options(key)[:display_text] %></span>

            <span class="text-sm text-base-content opacity-70"><%= privacy_setting_options(key)[:description_text] %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if organization.new_record? %>
    <%= f.submit class: "btn btn-primary btn-block" %>
  <% else %>
    <div class="flex justify-end"><%= f.submit class: "btn btn-primary" %></div>
  <% end %>
<% end %>
